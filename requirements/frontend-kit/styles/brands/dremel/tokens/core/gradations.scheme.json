{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "gradations",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "required": [
        "version"
      ],
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^(yellow|gray|green|turquoise|blue|purple|red)$": {
      "type": "object",
      "properties": {
        "$type": {
          "type": "string",
          "const": "color"
        }
      },
      "required": [
        "$type"
      ],
      "additionalProperties": {
        "type": "object",
        "properties": {
          "$value": {
            "type": "string",
            "pattern": "^#([0-9a-fA-F]{6})$"
          },
          "opacity": {
            "oneOf": [
              {
                "type": "string",
                "const": "unset"
              },
              {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            ]
          },
          "id": {
            "type": "string",
            "pattern": "^g_\\d{2}_\\d{2}$"
          },
          "var": {
            "type": "string"
          }
        },
        "required": [
          "$value",
          "opacity",
          "id",
          "var"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "meta"
  ],
  "additionalProperties": false
}