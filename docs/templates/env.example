# Environment variables — copy into a workspace as .env.example
# Document every variable the app reads. Commit ONLY this example file.
# Copy it to .env locally and fill in real values. Never commit a real .env.

# Application
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/appdb

# Secrets — leave blank here; set real values only in your local .env or secret store
API_KEY=
JWT_SECRET=
